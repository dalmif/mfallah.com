---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const presentations = (await getCollection('blog', (post) => post.data.presentation)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Presentations | ${SITE_TITLE}`}
			description="Talks and presentations by Mohammad Fallah"
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>Presentations</h1>
			<p>Talks I've given, mostly about Android development, software engineering, and AI.</p>
			<ul class="post-list">
				{
					presentations.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
		<style>
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				margin-bottom: 0.75em;
			}
			.date {
				margin-left: 0.75em;
				color: var(--text-light);
				font-size: 0.9em;
			}
		</style>
	</body>
</html>
